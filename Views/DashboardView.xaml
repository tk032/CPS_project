<UserControl x:Class="SmartFactoryCPS.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F1F5F9">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,10,32,16">

            <!-- ══ Three Info Cards ══ -->
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 현재 박스 정보 -->
                <Border Grid.Column="0" Style="{StaticResource CardStyle}" Background="#F8FAFC">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Viewbox Width="14" Height="14" Margin="0,0,7,0">
                                <Canvas Width="16" Height="16">
                                    <Path Stroke="#155DFC" StrokeThickness="1.5" Fill="Transparent"
                                          Data="M8,0.5 L15.5,4.5 L15.5,11.5 L8,15.5 L0.5,11.5 L0.5,4.5 Z
                                                M8,0.5 L8,8 M0.5,4.5 L8,8 M15.5,4.5 L8,8 M4.3,2.5 L11.7,6.5"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock Text="현재 박스 정보" FontSize="13" FontWeight="SemiBold"
                                       Foreground="#314158" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Center" Margin="0,10,0,10"
                                    Visibility="{Binding HasCurrentBox, Converter={StaticResource InvBoolVis}}">
                            <Viewbox Width="52" Height="52" HorizontalAlignment="Center" Margin="0,0,0,10">
                                <Canvas Width="40" Height="40">
                                    <Path Stroke="#90A1B9" StrokeThickness="2.5" Fill="Transparent"
                                          Data="M20,2 L38,12 L38,28 L20,38 L2,28 L2,12 Z
                                                M20,2 L20,20 M2,12 L20,20 M38,12 L20,20 M11,7 L29,17"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock Text="박스 대기 중..." Foreground="#90A1B9"
                                       FontSize="13" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Visibility="{Binding HasCurrentBox, Converter={StaticResource BoolVis}}">
                            <Border Background="#EFF6FF" CornerRadius="8" Padding="12,8" Margin="0,0,0,12">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="# " Foreground="#155DFC" FontSize="22" FontWeight="Bold"/>
                                    <TextBlock Foreground="#155DFC" FontSize="22" FontWeight="Bold"
                                               Text="{Binding CurrentBox.BoxId, StringFormat='{}{0:D3}'}"/>
                                </StackPanel>
                            </Border>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Text="목적지" Foreground="#6A7282" FontSize="13"/>
                                <TextBlock Grid.Column="1" FontWeight="SemiBold" FontSize="13"
                                           Foreground="#314158" Text="{Binding CurrentBox.RegionName}"/>
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Text="무게" Foreground="#6A7282" FontSize="13"/>
                                <TextBlock Grid.Column="1" FontWeight="SemiBold" FontSize="13"
                                           Foreground="#314158"
                                           Text="{Binding CurrentBox.Weight, StringFormat='{}{0:F1} kg'}"/>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Text="상태" Foreground="#6A7282" FontSize="13" VerticalAlignment="Center"/>
                                <Border Grid.Column="1" Style="{StaticResource BadgeStyle}"
                                        Background="{Binding CurrentBox.Status, Converter={StaticResource BadgeBg}}">
                                    <TextBlock FontSize="12" Text="{Binding CurrentBox.Status}"
                                               Foreground="{Binding CurrentBox.Status, Converter={StaticResource BadgeFg}}"/>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- 4분류지점 현황 -->
                <Border Grid.Column="2" Style="{StaticResource CardStyle}" Background="#F8FAFC">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Viewbox Width="14" Height="14" Margin="0,0,7,0">
                                <Canvas Width="16" Height="16">
                                    <Path Stroke="#00A63E" StrokeThickness="1.5" Fill="Transparent"
                                          Data="M2,8 L6,12 L14,4"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock Text="5분류 현황" FontSize="13" FontWeight="SemiBold"
                                       Foreground="#314158" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- SP1 서울 -->
                        <Grid Margin="0,0,0,7">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Ellipse Grid.Column="0" Width="10" Height="10" Fill="#2B7FFF"
                                     VerticalAlignment="Center" Margin="0,0,7,0"/>
                            <TextBlock Grid.Column="1" Text="SP1 서울" FontSize="12"
                                       FontWeight="SemiBold" Foreground="#314158" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="RFID " FontSize="10" Foreground="#6A7282" VerticalAlignment="Center"/>
                                <Ellipse Width="8" Height="8" Fill="#00A63E" VerticalAlignment="Center"
                                         Visibility="{Binding IsRfid1Scanning, Converter={StaticResource BoolVis}}"/>
                                <Ellipse Width="8" Height="8" Fill="#CBD5E1" VerticalAlignment="Center"
                                         Visibility="{Binding IsRfid1Scanning, Converter={StaticResource InvBoolVis}}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="PUSH " FontSize="10" Foreground="#6A7282" VerticalAlignment="Center"/>
                                <Ellipse Width="8" Height="8" Fill="#E7000B" VerticalAlignment="Center"
                                         Visibility="{Binding Push1Active, Converter={StaticResource BoolVis}}"/>
                                <Ellipse Width="8" Height="8" Fill="#CBD5E1" VerticalAlignment="Center"
                                         Visibility="{Binding Push1Active, Converter={StaticResource InvBoolVis}}"/>
                            </StackPanel>
                        </Grid>

                        <!-- SP2 대전 -->
                        <Grid Margin="0,0,0,7">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Ellipse Grid.Column="0" Width="10" Height="10" Fill="#AD46FF"
                                     VerticalAlignment="Center" Margin="0,0,7,0"/>
                            <TextBlock Grid.Column="1" Text="SP2 대전" FontSize="12"
                                       FontWeight="SemiBold" Foreground="#314158" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="RFID " FontSize="10" Foreground="#6A7282" VerticalAlignment="Center"/>
                                <Ellipse Width="8" Height="8" Fill="#00A63E" VerticalAlignment="Center"
                                         Visibility="{Binding IsRfid2Scanning, Converter={StaticResource BoolVis}}"/>
                                <Ellipse Width="8" Height="8" Fill="#CBD5E1" VerticalAlignment="Center"
                                         Visibility="{Binding IsRfid2Scanning, Converter={StaticResource InvBoolVis}}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="PUSH " FontSize="10" Foreground="#6A7282" VerticalAlignment="Center"/>
                                <Ellipse Width="8" Height="8" Fill="#E7000B" VerticalAlignment="Center"
                                         Visibility="{Binding Push2Active, Converter={StaticResource BoolVis}}"/>
                                <Ellipse Width="8" Height="8" Fill="#CBD5E1" VerticalAlignment="Center"
                                         Visibility="{Binding Push2Active, Converter={StaticResource InvBoolVis}}"/>
                            </StackPanel>
                        </Grid>

                        <!-- SP3 대구 -->
                        <Grid Margin="0,0,0,7">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Ellipse Grid.Column="0" Width="10" Height="10" Fill="#FF7B00"
                                     VerticalAlignment="Center" Margin="0,0,7,0"/>
                            <TextBlock Grid.Column="1" Text="SP3 대구" FontSize="12"
                                       FontWeight="SemiBold" Foreground="#314158" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="RFID " FontSize="10" Foreground="#6A7282" VerticalAlignment="Center"/>
                                <Ellipse Width="8" Height="8" Fill="#00A63E" VerticalAlignment="Center"
                                         Visibility="{Binding IsRfid3Scanning, Converter={StaticResource BoolVis}}"/>
                                <Ellipse Width="8" Height="8" Fill="#CBD5E1" VerticalAlignment="Center"
                                         Visibility="{Binding IsRfid3Scanning, Converter={StaticResource InvBoolVis}}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="PUSH " FontSize="10" Foreground="#6A7282" VerticalAlignment="Center"/>
                                <Ellipse Width="8" Height="8" Fill="#E7000B" VerticalAlignment="Center"
                                         Visibility="{Binding Push3Active, Converter={StaticResource BoolVis}}"/>
                                <Ellipse Width="8" Height="8" Fill="#CBD5E1" VerticalAlignment="Center"
                                         Visibility="{Binding Push3Active, Converter={StaticResource InvBoolVis}}"/>
                            </StackPanel>
                        </Grid>

                        <!-- SP4 부산 -->
                        <Grid Margin="0,0,0,7">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Ellipse Grid.Column="0" Width="10" Height="10" Fill="#00C950"
                                     VerticalAlignment="Center" Margin="0,0,7,0"/>
                            <TextBlock Grid.Column="1" Text="SP4 부산" FontSize="12"
                                       FontWeight="SemiBold" Foreground="#314158" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="RFID " FontSize="10" Foreground="#6A7282" VerticalAlignment="Center"/>
                                <Ellipse Width="8" Height="8" Fill="#00A63E" VerticalAlignment="Center"
                                         Visibility="{Binding IsRfid4Scanning, Converter={StaticResource BoolVis}}"/>
                                <Ellipse Width="8" Height="8" Fill="#CBD5E1" VerticalAlignment="Center"
                                         Visibility="{Binding IsRfid4Scanning, Converter={StaticResource InvBoolVis}}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="PUSH " FontSize="10" Foreground="#6A7282" VerticalAlignment="Center"/>
                                <Ellipse Width="8" Height="8" Fill="#E7000B" VerticalAlignment="Center"
                                         Visibility="{Binding Push4Active, Converter={StaticResource BoolVis}}"/>
                                <Ellipse Width="8" Height="8" Fill="#CBD5E1" VerticalAlignment="Center"
                                         Visibility="{Binding Push4Active, Converter={StaticResource InvBoolVis}}"/>
                            </StackPanel>
                        </Grid>

                        <Rectangle Fill="#E2E8F0" Height="1" Margin="0,4,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Text="현재 분류 대상" Foreground="#45556C" FontSize="13" VerticalAlignment="Center"/>
                            <Border Grid.Column="1" CornerRadius="8" Padding="10,4"
                                    BorderBrush="#E2E8F0" BorderThickness="1" Background="White">
                                <TextBlock Text="{Binding CurrentSortTarget}" FontSize="12"
                                           FontWeight="SemiBold" Foreground="#314158"/>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 알람/경고 -->
                <Border Grid.Column="4" Style="{StaticResource CardStyle}"
                        Background="{Binding HasActiveAlarm, Converter={StaticResource AlarmBg}}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Viewbox Width="15" Height="14" Margin="0,0,7,0">
                                <Canvas Width="17" Height="16">
                                    <Path Stroke="#E7000B" StrokeThickness="1.5" Fill="Transparent"
                                          Data="M8.5,1.5 L16,14.5 L1,14.5 Z"/>
                                    <Line X1="8.5" Y1="6" X2="8.5" Y2="10"
                                          Stroke="#E7000B" StrokeThickness="1.5"
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                    <Ellipse Canvas.Left="7.8" Canvas.Top="11.5"
                                             Width="1.4" Height="1.4" Fill="#E7000B"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock Text="알람 / 경고" FontSize="14" FontWeight="SemiBold"
                                       Foreground="#314158" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Center" Margin="0,10,0,10"
                                    Visibility="{Binding HasActiveAlarm, Converter={StaticResource InvBoolVis}}">
                            <Viewbox Width="52" Height="52" HorizontalAlignment="Center" Margin="0,0,0,10">
                                <Canvas Width="40" Height="40">
                                    <Path Stroke="#90A1B9" StrokeThickness="2.5" Fill="Transparent"
                                          Data="M20,3 L37,33 L3,33 Z"/>
                                    <Line X1="20" Y1="14" X2="20" Y2="24"
                                          Stroke="#90A1B9" StrokeThickness="2.5"
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                    <Ellipse Canvas.Left="18" Canvas.Top="27"
                                             Width="4" Height="4" Fill="#90A1B9"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock Text="활성 알람 없음" Foreground="#90A1B9"
                                       FontSize="13" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <Border Visibility="{Binding HasActiveAlarm, Converter={StaticResource BoolVis}}"
                                Background="#FEE2E2" CornerRadius="8" Padding="12"
                                BorderBrush="#FECACA" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="{Binding AlarmMessage}" Foreground="#E7000B"
                                           FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                <TextBlock Margin="0,6,0,0" Foreground="#E7000B" FontSize="12"
                                           Text="{Binding AlarmCode, StringFormat='알람 코드: {0}'}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ══ 컨베이어 라인 (5분류) ══ -->
            <Border Style="{StaticResource SectionStyle}" Margin="0,0,0,10">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="컨베이어 라인 (5분류)" FontSize="14" FontWeight="SemiBold"
                                   Foreground="#314158" VerticalAlignment="Center"/>
                        <Border Margin="10,0,0,0" CornerRadius="6" Padding="8,3"
                                Background="{Binding IsRunning, Converter={StaticResource AlarmBg}}">
                            <TextBlock Text="{Binding ConveyorStatus}" FontSize="11"
                                       Foreground="{Binding ConveyorStatus, Converter={StaticResource BadgeFg}}"/>
                        </Border>
                    </StackPanel>

                    <!-- Canvas: Width=960 matches BoxEntryX=55, SortPointX={208,383,558,733}, BoxExitX=940 -->
                    <Viewbox Height="162" HorizontalAlignment="Stretch" Stretch="Fill">
                        <Canvas Width="960" Height="162" ClipToBounds="True">

                            <!-- ▌Belt track background -->
                            <Rectangle Canvas.Left="0" Canvas.Top="38" Width="960" Height="20" Fill="#2D3748"/>

                            <!-- ▌Belt animated pattern -->
                            <Rectangle Canvas.Left="0" Canvas.Top="38" Width="1000" Height="20">
                                <Rectangle.Fill>
                                    <DrawingBrush TileMode="Tile" Viewport="0,0,40,20" ViewportUnits="Absolute">
                                        <DrawingBrush.Drawing>
                                            <DrawingGroup>
                                                <GeometryDrawing Brush="Transparent">
                                                    <GeometryDrawing.Geometry><RectangleGeometry Rect="0,0,40,20"/></GeometryDrawing.Geometry>
                                                </GeometryDrawing>
                                                <GeometryDrawing Brush="#3D4F66">
                                                    <GeometryDrawing.Geometry><PathGeometry Figures="M10,0 L22,0 L28,20 L16,20 Z"/></GeometryDrawing.Geometry>
                                                </GeometryDrawing>
                                            </DrawingGroup>
                                        </DrawingBrush.Drawing>
                                    </DrawingBrush>
                                </Rectangle.Fill>
                                <Rectangle.RenderTransform><TranslateTransform x:Name="BeltAnim"/></Rectangle.RenderTransform>
                                <Rectangle.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation Storyboard.TargetName="BeltAnim"
                                                                 Storyboard.TargetProperty="X"
                                                                 From="0" To="40" Duration="0:0:0.55"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Rectangle.Triggers>
                            </Rectangle>

                            <!-- Belt edge lines -->
                            <Rectangle Canvas.Left="0" Canvas.Top="38" Width="960" Height="2" Fill="#4A6080"/>
                            <Rectangle Canvas.Left="0" Canvas.Top="56" Width="960" Height="2" Fill="#1A2030"/>

                            <!-- Drive rollers -->
                            <Ellipse Canvas.Left="4"   Canvas.Top="34" Width="24" Height="24" Fill="#3D4F66" Stroke="#4A6080" StrokeThickness="2"/>
                            <Ellipse Canvas.Left="932" Canvas.Top="34" Width="24" Height="24" Fill="#3D4F66" Stroke="#4A6080" StrokeThickness="2"/>

                            <!-- Direction arrow -->
                            <Path Canvas.Left="34" Canvas.Top="41" Stroke="#4A6080" StrokeThickness="1.5"
                                  Fill="Transparent" Data="M0,6 L12,6 M7,1 L12,6 L7,11"/>

                            <!-- RFID0 write point (entry, x≈88) -->
                            <Rectangle Canvas.Left="87" Canvas.Top="0" Width="2" Height="58" Fill="#6B7280" Opacity="0.45"/>
                            <Border Canvas.Left="58" Canvas.Top="3" Background="#6B7280" CornerRadius="3" Padding="5,2">
                                <TextBlock Text="RFID0" FontSize="8" Foreground="White" FontWeight="Bold"/>
                            </Border>

                            <!-- ════ SP1 서울 (x=208) ════ -->
                            <Rectangle Canvas.Left="208" Canvas.Top="0" Width="3" Height="58" Fill="#2B7FFF" Opacity="0.7"/>
                            <Border Canvas.Left="176" Canvas.Top="3" Background="#2B7FFF" CornerRadius="3" Padding="5,2">
                                <TextBlock Text="RFID1" FontSize="8" Foreground="White" FontWeight="Bold"/>
                            </Border>
                            <!-- Scan beam (active only) -->
                            <Rectangle Canvas.Left="203" Canvas.Top="38" Width="13" Height="20"
                                       Visibility="{Binding IsRfid1Scanning, Converter={StaticResource BoolVis}}">
                                <Rectangle.Fill>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="Transparent" Offset="0"/>
                                        <GradientStop Color="#CC2B7FFF"   Offset="0.5"/>
                                        <GradientStop Color="Transparent" Offset="1"/>
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                            </Rectangle>
                            <!-- Pusher inactive -->
                            <Path Canvas.Left="201" Canvas.Top="62" Stroke="#94A3B8" StrokeThickness="2"
                                  Fill="Transparent" Data="M6,0 L6,14 M1,9 L6,14 L11,9"
                                  Visibility="{Binding Push1Active, Converter={StaticResource InvBoolVis}}"/>
                            <!-- Pusher active -->
                            <Path Canvas.Left="201" Canvas.Top="62" Stroke="#2B7FFF" StrokeThickness="2.5"
                                  Fill="Transparent" Data="M6,0 L6,14 M1,9 L6,14 L11,9"
                                  Visibility="{Binding Push1Active, Converter={StaticResource BoolVis}}"/>
                            <!-- Bin -->
                            <Rectangle Canvas.Left="183" Canvas.Top="84" Width="52" Height="50"
                                       Fill="#EFF6FF" RadiusX="4" RadiusY="4"
                                       Stroke="#2B7FFF" StrokeThickness="1.5"/>
                            <!-- Bin active highlight -->
                            <Rectangle Canvas.Left="183" Canvas.Top="84" Width="52" Height="50"
                                       Fill="#2B7FFF" Opacity="0.12" RadiusX="4" RadiusY="4"
                                       Visibility="{Binding Push1Active, Converter={StaticResource BoolVis}}"/>
                            <TextBlock Canvas.Left="183" Canvas.Top="100" Width="52"
                                       TextAlignment="Center" Text="서울"
                                       FontSize="11" FontWeight="Bold" Foreground="#2B7FFF"/>

                            <!-- ════ SP2 대전 (x=383) ════ -->
                            <Rectangle Canvas.Left="383" Canvas.Top="0" Width="3" Height="58" Fill="#AD46FF" Opacity="0.7"/>
                            <Border Canvas.Left="351" Canvas.Top="3" Background="#AD46FF" CornerRadius="3" Padding="5,2">
                                <TextBlock Text="RFID2" FontSize="8" Foreground="White" FontWeight="Bold"/>
                            </Border>
                            <Rectangle Canvas.Left="378" Canvas.Top="38" Width="13" Height="20"
                                       Visibility="{Binding IsRfid2Scanning, Converter={StaticResource BoolVis}}">
                                <Rectangle.Fill>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="Transparent" Offset="0"/>
                                        <GradientStop Color="#CCAD46FF"   Offset="0.5"/>
                                        <GradientStop Color="Transparent" Offset="1"/>
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                            </Rectangle>
                            <Path Canvas.Left="376" Canvas.Top="62" Stroke="#94A3B8" StrokeThickness="2"
                                  Fill="Transparent" Data="M6,0 L6,14 M1,9 L6,14 L11,9"
                                  Visibility="{Binding Push2Active, Converter={StaticResource InvBoolVis}}"/>
                            <Path Canvas.Left="376" Canvas.Top="62" Stroke="#AD46FF" StrokeThickness="2.5"
                                  Fill="Transparent" Data="M6,0 L6,14 M1,9 L6,14 L11,9"
                                  Visibility="{Binding Push2Active, Converter={StaticResource BoolVis}}"/>
                            <Rectangle Canvas.Left="358" Canvas.Top="84" Width="52" Height="50"
                                       Fill="#FAF5FF" RadiusX="4" RadiusY="4"
                                       Stroke="#AD46FF" StrokeThickness="1.5"/>
                            <Rectangle Canvas.Left="358" Canvas.Top="84" Width="52" Height="50"
                                       Fill="#AD46FF" Opacity="0.12" RadiusX="4" RadiusY="4"
                                       Visibility="{Binding Push2Active, Converter={StaticResource BoolVis}}"/>
                            <TextBlock Canvas.Left="358" Canvas.Top="100" Width="52"
                                       TextAlignment="Center" Text="대전"
                                       FontSize="11" FontWeight="Bold" Foreground="#AD46FF"/>

                            <!-- ════ SP3 대구 (x=558) ════ -->
                            <Rectangle Canvas.Left="558" Canvas.Top="0" Width="3" Height="58" Fill="#FF7B00" Opacity="0.7"/>
                            <Border Canvas.Left="526" Canvas.Top="3" Background="#FF7B00" CornerRadius="3" Padding="5,2">
                                <TextBlock Text="RFID3" FontSize="8" Foreground="White" FontWeight="Bold"/>
                            </Border>
                            <Rectangle Canvas.Left="553" Canvas.Top="38" Width="13" Height="20"
                                       Visibility="{Binding IsRfid3Scanning, Converter={StaticResource BoolVis}}">
                                <Rectangle.Fill>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="Transparent" Offset="0"/>
                                        <GradientStop Color="#CCFF7B00"   Offset="0.5"/>
                                        <GradientStop Color="Transparent" Offset="1"/>
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                            </Rectangle>
                            <Path Canvas.Left="551" Canvas.Top="62" Stroke="#94A3B8" StrokeThickness="2"
                                  Fill="Transparent" Data="M6,0 L6,14 M1,9 L6,14 L11,9"
                                  Visibility="{Binding Push3Active, Converter={StaticResource InvBoolVis}}"/>
                            <Path Canvas.Left="551" Canvas.Top="62" Stroke="#FF7B00" StrokeThickness="2.5"
                                  Fill="Transparent" Data="M6,0 L6,14 M1,9 L6,14 L11,9"
                                  Visibility="{Binding Push3Active, Converter={StaticResource BoolVis}}"/>
                            <Rectangle Canvas.Left="533" Canvas.Top="84" Width="52" Height="50"
                                       Fill="#FFF7ED" RadiusX="4" RadiusY="4"
                                       Stroke="#FF7B00" StrokeThickness="1.5"/>
                            <Rectangle Canvas.Left="533" Canvas.Top="84" Width="52" Height="50"
                                       Fill="#FF7B00" Opacity="0.12" RadiusX="4" RadiusY="4"
                                       Visibility="{Binding Push3Active, Converter={StaticResource BoolVis}}"/>
                            <TextBlock Canvas.Left="533" Canvas.Top="100" Width="52"
                                       TextAlignment="Center" Text="대구"
                                       FontSize="11" FontWeight="Bold" Foreground="#FF7B00"/>

                            <!-- ════ SP4 부산 (x=733) ════ -->
                            <Rectangle Canvas.Left="733" Canvas.Top="0" Width="3" Height="58" Fill="#00C950" Opacity="0.7"/>
                            <Border Canvas.Left="701" Canvas.Top="3" Background="#00C950" CornerRadius="3" Padding="5,2">
                                <TextBlock Text="RFID4" FontSize="8" Foreground="White" FontWeight="Bold"/>
                            </Border>
                            <Rectangle Canvas.Left="728" Canvas.Top="38" Width="13" Height="20"
                                       Visibility="{Binding IsRfid4Scanning, Converter={StaticResource BoolVis}}">
                                <Rectangle.Fill>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="Transparent" Offset="0"/>
                                        <GradientStop Color="#CC00C950"   Offset="0.5"/>
                                        <GradientStop Color="Transparent" Offset="1"/>
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                            </Rectangle>
                            <Path Canvas.Left="726" Canvas.Top="62" Stroke="#94A3B8" StrokeThickness="2"
                                  Fill="Transparent" Data="M6,0 L6,14 M1,9 L6,14 L11,9"
                                  Visibility="{Binding Push4Active, Converter={StaticResource InvBoolVis}}"/>
                            <Path Canvas.Left="726" Canvas.Top="62" Stroke="#00C950" StrokeThickness="2.5"
                                  Fill="Transparent" Data="M6,0 L6,14 M1,9 L6,14 L11,9"
                                  Visibility="{Binding Push4Active, Converter={StaticResource BoolVis}}"/>
                            <Rectangle Canvas.Left="708" Canvas.Top="84" Width="52" Height="50"
                                       Fill="#F0FDF4" RadiusX="4" RadiusY="4"
                                       Stroke="#00C950" StrokeThickness="1.5"/>
                            <Rectangle Canvas.Left="708" Canvas.Top="84" Width="52" Height="50"
                                       Fill="#00C950" Opacity="0.12" RadiusX="4" RadiusY="4"
                                       Visibility="{Binding Push4Active, Converter={StaticResource BoolVis}}"/>
                            <TextBlock Canvas.Left="708" Canvas.Top="100" Width="52"
                                       TextAlignment="Center" Text="부산"
                                       FontSize="11" FontWeight="Bold" Foreground="#00A63E"/>

                            <!-- ════ 기타 (벨트 끝, x≈880) — Push 없이 낙하 ════ -->
                            <Rectangle Canvas.Left="858" Canvas.Top="58" Width="2" Height="26"
                                       Fill="#94A3B8" Opacity="0.5"/>
                            <Path Canvas.Left="852" Canvas.Top="57" Stroke="#94A3B8" StrokeThickness="1.5"
                                  Fill="Transparent" Data="M6,0 L0,10 L12,10 Z"/>
                            <Rectangle Canvas.Left="842" Canvas.Top="84" Width="52" Height="50"
                                       Fill="#F8FAFC" RadiusX="4" RadiusY="4"
                                       Stroke="#94A3B8" StrokeThickness="1.5"/>
                            <TextBlock Canvas.Left="842" Canvas.Top="100" Width="52"
                                       TextAlignment="Center" Text="기타"
                                       FontSize="11" FontWeight="Bold" Foreground="#64748B"/>

                            <!-- ▌Multi-box ItemsControl (boxes move left→right on belt) -->
                            <ItemsControl Canvas.Left="0" Canvas.Top="0"
                                          Width="960" Height="62"
                                          ItemsSource="{Binding ConveyorBoxes}"
                                          IsHitTestVisible="False">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas Width="960" Height="62" ClipToBounds="True"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                        <Setter Property="Canvas.Top"  Value="30"/>
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <!-- 박스 그림만 표시 (라벨 없음) -->
                                        <Border Width="48" Height="26"
                                                Background="#A07244" CornerRadius="4"
                                                BorderBrush="#7A5030" BorderThickness="1">
                                            <Border.Effect>
                                                <DropShadowEffect BlurRadius="4" ShadowDepth="1"
                                                                  Color="#000" Opacity="0.3"/>
                                            </Border.Effect>
                                            <Canvas Width="48" Height="26">
                                                <Rectangle Canvas.Left="6"  Canvas.Top="9"  Width="36" Height="1" Fill="#7A5030" Opacity="0.4"/>
                                                <Rectangle Canvas.Left="6"  Canvas.Top="16" Width="36" Height="1" Fill="#7A5030" Opacity="0.4"/>
                                                <Rectangle Canvas.Left="24" Canvas.Top="3"  Width="1" Height="20" Fill="#7A5030" Opacity="0.3"/>
                                            </Canvas>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </Canvas>
                    </Viewbox>
                </StackPanel>
            </Border>

            <!-- ══ 지역별 누적 통계 ══ -->
            <Border Style="{StaticResource SectionStyle}" Margin="0,0,0,10">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="지역별 누적 통계" FontSize="14" FontWeight="SemiBold"
                                   Foreground="#314158" VerticalAlignment="Center"/>
                    </StackPanel>
                    <ItemsControl ItemsSource="{Binding RegionStats}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><UniformGrid Rows="1" Columns="5"/></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource RegCardStyle}">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#F8FAFC" Offset="0"/>
                                            <GradientStop Color="#F1F5F9" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                            <Ellipse Width="12" Height="12" Fill="{Binding DotColor}"
                                                     VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding RegionName}" FontSize="14"
                                                       FontWeight="SemiBold" Foreground="#314158"/>
                                        </StackPanel>
                                        <TextBlock Text="수량" Foreground="#6A7282" FontSize="10" Margin="0,0,0,2"/>
                                        <TextBlock Text="{Binding Count}" FontSize="22"
                                                   FontWeight="Bold" Foreground="#1D293D" Margin="0,0,0,6"/>
                                        <TextBlock Text="누적 무게" Foreground="#6A7282" FontSize="10" Margin="0,0,0,2"/>
                                        <TextBlock Text="{Binding TotalWeight, StringFormat='{}{0:F1} kg'}"
                                                   FontSize="13" FontWeight="SemiBold" Foreground="#314158"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Rectangle Fill="#E2E8F0" Height="1" Margin="0,10,0,0"/>
                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="1"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                            <TextBlock Text="총 처리량" Foreground="#6A7282" FontSize="12"
                                       HorizontalAlignment="Center" Margin="0,0,0,4"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding TotalProcessed}" FontSize="24"
                                           FontWeight="Bold" Foreground="#1D293D"/>
                                <TextBlock Text=" 건" Foreground="#6A7282" FontSize="14"
                                           VerticalAlignment="Bottom" Margin="0,0,0,4"/>
                            </StackPanel>
                        </StackPanel>
                        <Rectangle Grid.Column="1" Fill="#E2E8F0"/>
                        <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                            <TextBlock Text="분당 처리량" Foreground="#6A7282" FontSize="12"
                                       HorizontalAlignment="Center" Margin="0,0,0,4"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding ThroughputPerMinute}" FontSize="24"
                                           FontWeight="Bold" Foreground="#1D293D"/>
                                <TextBlock Text=" 건/분" Foreground="#6A7282" FontSize="14"
                                           VerticalAlignment="Bottom" Margin="0,0,0,4"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ══ 최근 이벤트 로그 ══ -->
            <Border Style="{StaticResource SectionStyle}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="최근 이벤트 로그" FontSize="14" FontWeight="SemiBold"
                                   Foreground="#314158" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel HorizontalAlignment="Center" Margin="0,20,0,20"
                                Visibility="{Binding HasEvents, Converter={StaticResource InvBoolVis}}">
                        <TextBlock Text="이벤트 없음" Foreground="#90A1B9"
                                   FontSize="13" HorizontalAlignment="Center"/>
                    </StackPanel>
                    <Grid Margin="0,0,0,4" Visibility="{Binding HasEvents, Converter={StaticResource BoolVis}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="55"/>
                            <ColumnDefinition Width="65"/>
                            <ColumnDefinition Width="85"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="시간"    FontSize="11" Foreground="#94A3B8" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="1" Text="박스 ID" FontSize="11" Foreground="#94A3B8" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="2" Text="목적지"  FontSize="11" Foreground="#94A3B8" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="3" Text="무게"    FontSize="11" Foreground="#94A3B8" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="4" Text="상태"    FontSize="11" Foreground="#94A3B8" FontWeight="SemiBold"/>
                    </Grid>
                    <Rectangle Fill="#E2E8F0" Height="1" Margin="0,0,0,4"
                               Visibility="{Binding HasEvents, Converter={StaticResource BoolVis}}"/>
                    <ItemsControl ItemsSource="{Binding EventLogs}"
                                  Visibility="{Binding HasEvents, Converter={StaticResource BoolVis}}"
                                  MaxHeight="160">
                        <ItemsControl.Template>
                            <ControlTemplate TargetType="ItemsControl">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsPresenter/>
                                </ScrollViewer>
                            </ControlTemplate>
                        </ItemsControl.Template>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10,7" CornerRadius="6" Margin="0,2" Background="#F8FAFC">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="55"/>
                                            <ColumnDefinition Width="65"/>
                                            <ColumnDefinition Width="85"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" FontSize="12" Foreground="#6A7282"
                                                   Text="{Binding Timestamp, StringFormat='HH:mm:ss'}"/>
                                        <TextBlock Grid.Column="1" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="#314158"
                                                   Text="{Binding BoxId, StringFormat='#{0:D3}'}"/>
                                        <TextBlock Grid.Column="2" FontSize="12" Foreground="#314158"
                                                   Text="{Binding RegionName}"/>
                                        <TextBlock Grid.Column="3" FontSize="12" Foreground="#314158"
                                                   Text="{Binding Weight, StringFormat='{}{0:F1} kg'}"/>
                                        <TextBlock Grid.Column="4" FontSize="12" FontWeight="SemiBold"
                                                   Text="{Binding Status}"
                                                   Foreground="{Binding Status, Converter={StaticResource EventStatusColor}}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
