<UserControl x:Class="SmartFactoryCPS.Views.AdminView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F1F5F9">

    <UserControl.Resources>
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Height"          Value="34"/>
            <Setter Property="Padding"         Value="16,0"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter Property="Opacity" Value="0.85"/></Trigger>
                            <Trigger Property="IsEnabled"   Value="False"><Setter Property="Opacity" Value="0.4"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="Height"          Value="34"/>
            <Setter Property="Padding"         Value="10,0"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush"     Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background"      Value="White"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,20,32,20">

            <!-- 페이지 타이틀 -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <TextBlock Text="관리자 페이지" FontSize="20" FontWeight="Bold" Foreground="#1D293D"/>
                <Border Margin="12,0,0,0" Background="#F1F5F9" CornerRadius="6" Padding="10,4"
                        BorderBrush="#E2E8F0" BorderThickness="1" VerticalAlignment="Center">
                    <TextBlock Text="CRUD 관리" FontSize="12" Foreground="#64748B"/>
                </Border>
                <Border Margin="8,0,0,0" Background="#EFF6FF" CornerRadius="6" Padding="10,4"
                        BorderBrush="#BFDBFE" BorderThickness="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding LocLabel}" FontSize="12" Foreground="#155DFC" FontWeight="SemiBold"/>
                </Border>
            </StackPanel>

            <!-- ══ 분류 이력 관리 ══ -->
            <Border Style="{StaticResource SectionStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <!-- 섹션 헤더 -->
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal">
                            <Border Width="4" Height="18" Background="#155DFC" CornerRadius="2" Margin="0,0,10,0"/>
                            <TextBlock Text="분류 이력 관리" FontSize="15" FontWeight="SemiBold" Foreground="#1D293D" VerticalAlignment="Center"/>
                            <Border Margin="10,0,0,0" Background="#EFF6FF" CornerRadius="10" Padding="8,3">
                                <TextBlock Text="{Binding ParcelCount, StringFormat='{}{0}건'}"
                                           FontSize="12" Foreground="#155DFC" FontWeight="SemiBold"/>
                            </Border>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <!-- 지역 필터 -->
                            <ComboBox Width="110" Height="34" Margin="0,0,8,0"
                                      FontSize="13" VerticalContentAlignment="Center"
                                      ItemsSource="{Binding RegionFilterOptions}"
                                      SelectedItem="{Binding SelectedRegionFilter}"
                                      DisplayMemberPath="Label"/>
                            <!-- 키워드 검색 -->
                            <TextBox Style="{StaticResource InputBox}" Width="160" Margin="0,0,8,0"
                                     Text="{Binding ParcelSearch, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Style="{StaticResource ActionBtn}" Background="#155DFC"
                                    Command="{Binding LoadParcelsCommand}" Margin="0,0,8,0">새로고침</Button>
                            <!-- 전체 선택/해제 -->
                            <Button Style="{StaticResource ActionBtn}" Background="#475569"
                                    Command="{Binding SelectAllCommand}" Margin="0,0,4,0">전체선택</Button>
                            <Button Style="{StaticResource ActionBtn}" Background="#475569"
                                    Command="{Binding DeselectAllCommand}" Margin="0,0,8,0">선택해제</Button>
                            <!-- 선택 삭제 (선택 건수 표시) -->
                            <Button Style="{StaticResource ActionBtn}" Background="#E7000B"
                                    Command="{Binding DeleteSelectedParcelsCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="선택 삭제"/>
                                    <Border Background="#C0001B" CornerRadius="8" Padding="5,0" Margin="6,0,0,0"
                                            Visibility="{Binding HasSelectedItems, Converter={StaticResource BoolVis}}">
                                        <TextBlock Text="{Binding SelectedCount}" FontSize="11" Foreground="White"/>
                                    </Border>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <!-- DataGrid -->
                    <DataGrid ItemsSource="{Binding Parcels}"
                              SelectedItem="{Binding SelectedParcel}"
                              MaxHeight="280" IsReadOnly="False"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False">
                        <DataGrid.Columns>
                            <!-- 체크박스 컬럼 -->
                            <DataGridTemplateColumn Header="✓" Width="38" CanUserSort="False">
                                <DataGridTemplateColumn.HeaderTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="✓" HorizontalAlignment="Center"
                                                   FontSize="12" Foreground="#64748B"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.HeaderTemplate>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="ID"     Binding="{Binding Id}"         Width="55"  IsReadOnly="True"/>
                            <DataGridTextColumn Header="박스 ID" Binding="{Binding BoxId, StringFormat='#{0:D3}'}" Width="75" IsReadOnly="True"/>
                            <DataGridTextColumn Header="목적지"  Binding="{Binding RegionName}" Width="75"  IsReadOnly="True"/>
                            <DataGridTextColumn Header="무게"    Binding="{Binding WeightKg, StringFormat='{}{0:F1} kg'}" Width="75" IsReadOnly="True"/>
                            <DataGridTextColumn Header="결과"    Binding="{Binding SortResult}" Width="65"  IsReadOnly="True"/>
                            <DataGridTextColumn Header="분류 시간" Binding="{Binding SortedAt, StringFormat='yyyy-MM-dd HH:mm:ss'}" Width="*" IsReadOnly="True"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

            <!-- ══ DB 초기화 ══ -->
            <Border Style="{StaticResource SectionStyle}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                        <Border Width="4" Height="18" Background="#E7000B" CornerRadius="2" Margin="0,0,10,0"/>
                        <TextBlock Text="DB 초기화" FontSize="15" FontWeight="SemiBold" Foreground="#1D293D" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Border Background="#FFF1F2" CornerRadius="8" Padding="16,12"
                            BorderBrush="#FECACA" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="분류 이력 · 이벤트 로그 · 알람 기록을 모두 삭제합니다."
                                           FontSize="13" Foreground="#991B1B"/>
                                <TextBlock Text="이 작업은 되돌릴 수 없습니다."
                                           FontSize="12" Foreground="#B91C1C" Margin="0,2,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1" Style="{StaticResource ActionBtn}"
                                    Background="#E7000B" Command="{Binding ClearDbCommand}"
                                    Padding="20,0">DB 전체 초기화</Button>
                        </Grid>
                    </Border>
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="#E7000B" FontSize="12"
                               Margin="0,8,0,0"
                               Visibility="{Binding HasError, Converter={StaticResource BoolVis}}"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
